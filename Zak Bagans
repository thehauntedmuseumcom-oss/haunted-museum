<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Paranormal Experience</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600&family=Montserrat:wght@300&display=swap" rel="stylesheet">

<style>

body {
    margin:0;
    font-family: 'Montserrat', sans-serif;
    color:#fff;
    background: black;
    overflow-x:hidden;
}

/* GHOST BACKGROUND */
body::before {
    content:"";
    position:fixed;
    width:100%;
    height:100%;
    background:url('https://images.unsplash.com/photo-1509248961158-e54f6934749c') center/cover no-repeat;
    opacity:0.25;
    z-index:-1;
    animation:float 20s infinite linear;
}

@keyframes float {
    0% {transform:scale(1) translateY(0);}
    50% {transform:scale(1.05) translateY(-20px);}
    100% {transform:scale(1) translateY(0);}
}

/* HERO */
.hero {
    height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
}

.hero h1 {
    font-family:'Cinzel', serif;
    font-size:55px;
    letter-spacing:3px;
}

button {
    background:crimson;
    border:none;
    padding:15px;
    color:white;
    width:100%;
    cursor:pointer;
}

.section {
    max-width:1000px;
    margin:auto;
    padding:50px 20px;
}

.card {
    background:#111;
    border:1px solid #222;
    padding:20px;
    margin-bottom:20px;
    border-radius:10px;
}

input, select {
    width:100%;
    padding:12px;
    margin-top:10px;
    background:black;
    border:1px solid #333;
    color:white;
}

h2 {
    font-family:'Cinzel', serif;
}

.footer {
    text-align:center;
    padding:30px;
    color:#888;
}

</style>
</head>

<body>

<!-- HERO -->
<div class="hero">
<div>
<h1>ENTER THE UNKNOWN</h1>
<p>Not everyone is meant to experience this</p>
<button onclick="goBooking()">Book Your Experience</button>
</div>
</div>

<!-- PRICING -->
<div class="section">
<h2>Experiences & Access</h2>

<div class="card">Live Streaming Paranormal Experience — $100</div>
<div class="card">Tour Ticket — $250</div>
<div class="card">Live Investigation with Crew — $700</div>
<div class="card">Mystery Box (Haunted Artefacts) — $500</div>
<div class="card">VIP Membership Community — $300</div>
<div class="card">Lifetime VIP Silver Coin — $1000</div>
<div class="card">Ghost T-Shirt — $100</div>
<div class="card">Ghost Hoodie — $200</div>

</div>

<!-- BOOKING -->
<div class="section" id="booking">
<h2>Secure Your Spot</h2>

<form action="https://formsubmit.co/thehauntedmuseum.com@gmail.com" method="POST">

<div class="card">

<select id="package" name="Package">
<option value="100">Live Streaming — $100</option>
<option value="250">Tour Ticket — $250</option>
<option value="700">Live Investigation — $700</option>
<option value="500">Mystery Box — $500</option>
<option value="300">VIP Membership — $300</option>
<option value="1000">VIP Silver Coin — $1000</option>
<option value="100">T-Shirt — $100</option>
<option value="200">Hoodie — $200</option>
</select>

<input type="date" name="Date" required>
<input type="time" name="Time" required>

<input type="text" name="Name" placeholder="Full Name" required>
<input type="email" name="Email" placeholder="Email Address" required>

</div>

<div class="card">
<h3>Payment</h3>

<button type="button" onclick="payCard()">Pay with Card</button>

<p>Bitcoin options:</p>
<p>
<a href="https://www.moonpay.com" target="_blank">MoonPay</a> |
<a href="https://www.paybis.com" target="_blank">Paybis</a> |
<a href="https://www.changelly.com" target="_blank">Changelly</a>
</p>

<p id="wallet">bc1qlz2u0sgeqrz7t9dwark7gr7cal5t3zput9kq6a</p>

<button type="button" onclick="copyWallet()">Copy Wallet</button>

</div>

<div class="card">
<h3>Order Summary</h3>
<p id="summary">No selection yet</p>
</div>

<button type="submit">Confirm Booking</button>

</form>

</div>

<div class="footer">
© 2026 Paranormal Experience | Restricted Access
</div>

<script>

function goBooking(){
    document.getElementById("booking").scrollIntoView({behavior:"smooth"});
}

const pkg = document.getElementById("package");
const summary = document.getElementById("summary");

pkg.addEventListener("change", function(){
    summary.innerHTML = "Selected: $" + pkg.value;
});

function copyWallet(){
    navigator.clipboard.writeText(document.getElementById("wallet").innerText);
    alert("Wallet copied");
}

function payCard(){
    window.location.href="https://your-stripe-link.com";
}

</script>

</body>
</html>
